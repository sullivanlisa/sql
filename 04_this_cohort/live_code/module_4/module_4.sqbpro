="73"/><column index="2" value="80"/><column index="3" value="98"/><column index="4" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="string_manipulations*">/* MODULE 4 */
/* String Manipulations */


/* 1. ltrim, rtrim, trim*/
SELECT trim('500,000KRW', 'KRW') AS trimf, ltrim('500,000KRW', 'KRW') AS triml, rtrim('500,000KRW', 'KRW') AS trimr

/* 2. replace*/

SELECT replace('500,000KRW', 'KRW', 'CAD')

/* 3. upper, lower*/

SELECT upper('memememe'), lower('HIHIHIHIH')

/* 4. concat with || */
SELECT '500,000' || 'KRW'

/* 5. substr */

SELECT substr('500,000KRW', -3, 3)

/* 6. length */

SELECT length('500,000KRW')

/* 7. unicode, char */

SELECT char(80), unicode('n')


/* 8. REGEXP in a WHERE statement */

SELECT * FROM product
WHERE  product_name  REGEXP '([Pp]ie)'



--------------------------------------------------------------------------------------------------------------------------------------------
</sql><sql name="substr_instr_together">/* MODULE 4 */
/* Substring &amp; instring together */


/* think of this as a comma delimiter ... but it's a bit silly ... do this in python/R instead unless you have to */

SELECT 
'FirstWord, SecondWord, ThirdWord',
 SUBSTR('FirstWord, SecondWord, ThirdWord',0, INSTR('FirstWord, SecondWord, ThirdWord',',')) as FirstDelim
 --,SUBSTR('FirstWord, SecondWord, ThirdWord',0, 10) as FirstDelim -- same thing but not dynamic
 ,SUBSTR('FirstWord, SecondWord, ThirdWord', 
  INSTR('FirstWord, SecondWord, ThirdWord',',')+1,
  INSTR('FirstWord, SecondWord, ThirdWord',',')+1) as SecondDelim
  
  ,SUBSTR('FirstWord, SecondWord, ThirdWord',
  INSTR(
    (SUBSTR('FirstWord, SecondWord, ThirdWord',
    INSTR('FirstWord, SecondWord, ThirdWord',',')+1))
  ,',') + 
  INSTR('FirstWord, SecondWord, ThirdWord',',')+1) AS ThirdDelim



--------------------------------------------------------------------------------------------------------------------------------------------
</sql><sql name="UNION_UNION_ALL*">/* MODULE 4 */
/* UNION */

/* 1. Find the most and least expensive product by vendor with UNION (and row_number!) */

SELECT * FROM  (SELECT vendor_id, product_id, original_price,
		row_number() OVER (PARTITION BY vendor_id ORDER BY original_price DESC) price_rank
	FROM vendor_inventory)
WHERE price_rank = 1
UNION
SELECT * FROM  (SELECT vendor_id, product_id, original_price,
		row_number() OVER (PARTITION BY vendor_id ORDER BY original_price ASC) price_rank
	FROM vendor_inventory)
WHERE price_rank = 1

--------------------------------------------------------------------------------------------------------------------------------------------
</sql><sql name="FULL_OUTER_JOIN_UNION*">/* MODULE 4 */
/* UNION */

/* 1. Emulate a FULL OUTER JOIN with a UNION */
DROP TABLE IF EXISTS temp.store1; 
CREATE TEMP TABLE IF NOT EXISTS temp.store1
(
costume TEXT,
quantity INT
);

INSERT INTO temp.store1
VALUES(&quot;tiger&quot;,6),
        (&quot;elephant&quot;,2),
        (&quot;princess&quot;, 4);


DROP TABLE IF EXISTS temp.store2;
CREATE TEMP TABLE IF NOT EXISTS temp.store2
(
costume TEXT,
quantity INT
);

INSERT INTO temp.store2
VALUES(&quot;tiger&quot;,2),
	(&quot;dancer&quot;,7),
	(&quot;superhero&quot;, 5);
	
SELECT s1.quantity, s1.costume, s2.quantity
FROM store1 s1
LEFT JOIN store2 s2 ON s1.costume = s2.costume

UNION ALL

SELECT s1.quantity, s2.costume, s2.quantity
FROM store2 s2
LEFT JOIN store1 s1 ON s1.costume = s2.costume

WHERE s1.quantity IS NULL




--------------------------------------------------------------------------------------------------------------------------------------------
</sql><sql name="INTERSECT_EXCEPT*">/* MODULE 4 */
/* INTERSECT &amp; EXCEPT */

/* 1. Find products that have been sold (e.g. are in customer purchases AND product) */ 

SELECT product_id FROM product
INTERSECT
SELECT product_id FROM customer_purchases;

/* 2. Find products that have NOT been sold (e.g. are NOT in customer purchases even though in product) */

SELECT product_id FROM product
EXCEPT
SELECT product_id FROM customer_purchases;

/* 3. Directions matter... if we switch the order here:
products that do not exist, because no products purchased are NOT in the product table (e.g. are NOT in product even though in customer purchases)*/

SELECT product_id FROM customer_purchases
EXCEPT
SELECT product_id FROM product;

/* 4. We can remake the intersect with a WHERE subquery for more details ...  */

SELECT product_name, product_qty_type, product_size FROM product
WHERE( product_id IN
	(SELECT product_id FROM product
	INTERSECT
	SELECT product_id FROM customer_purchases)
)



</sql><current_tab id="4"/></tab_sql></sqlb_project>
