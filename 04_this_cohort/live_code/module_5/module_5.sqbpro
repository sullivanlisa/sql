/* SELF JOIN */


/* 1. Create a self-joining hierarchy */

DROP TABLE IF EXISTS TEMP.employees;
CREATE TEMP TABLE TEMP.employees 
(
emp_id INT
,emp_name text
,mgr_id INT
);

INSERT INTO TEMP.employees
VALUES(1,'Thomas',3)
,(2,'Niyaz', 4)
,(3,'Rohan', NULL)
,(4, 'Jennie',3);

SELECT e.emp_name AS employee_name, m.emp_name as manager_name FROM TEMP.employees e
LEFT JOIN temp.employees m
ON e.mgr_id = m.emp_id;
</sql><current_tab id="2"/></tab_sql></sqlb_project>
